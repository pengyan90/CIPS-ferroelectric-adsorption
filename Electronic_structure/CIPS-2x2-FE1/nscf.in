&CONTROL
  calculation = 'nscf',
  pseudo_dir = './',
  outdir='./'
  prefix = 'test',
etot_conv_thr=1.D-7,
forc_conv_thr=2.D-6,
nstep =200,

/
&SYSTEM
  ibrav = 4,
  celldm(1) = 22.88689,
  celldm(3) = 2.16601,
  nat = 40,
  ntyp = 4,
  ecutwfc = 40,
  ecutrho = 320,
  occupations = 'smearing',
  smearing = 'gaussian',
  degauss = 0.01,
  input_dft = 'pbe',
  vdw_corr = 'grimme-d2',
  london_s6 = 0.5,
  nbnd = 250,
/
&ELECTRONS
  electron_maxstep = 100,
  diagonalization = 'cg',
  conv_thr = 1.0d-8,
  mixing_beta = 0.2,
/
&IONS
/
&CELL
  press = 0.0,
/
