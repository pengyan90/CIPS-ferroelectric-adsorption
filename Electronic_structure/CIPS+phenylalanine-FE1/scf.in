forc_conv_thr=2.D-6,
nstep =200,

/
&SYSTEM
  ibrav = 4,
  celldm(1) = 22.88689,
  celldm(3) = 2.16601,
  nat = 63,
  ntyp = 8,
  ecutwfc = 40,
